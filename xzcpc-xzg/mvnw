#!/bin/sh
# Maven Wrapper
BASEDIR=$(dirname "$0")
WRAPPER_JAR="$BASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Maven Wrapper JAR not found, downloading..."
  mkdir -p "$BASEDIR/.mvn/wrapper"
  curl -fsSL "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar" -o "$WRAPPER_JAR"
fi

exec java -Dmaven.multiModuleProjectDirectory="$BASEDIR" -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
